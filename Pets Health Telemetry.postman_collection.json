          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status is 200 OK', () => pm.response.to.have.status(200));",
                  "",
                  "pm.test('Response is an array', () => {",
                  "    pm.expect(pm.response.json()).to.be.an('array');",
                  "});",
                  "",
                  "pm.test('Each screen has id, name, hasAds, buttons', () => {",
                  "    const screens = pm.response.json();",
                  "    if (screens.length > 0) {",
                  "        const s = screens[0];",
                  "        pm.expect(s).to.have.all.keys('id','schema','name','hasAds','buttons');",
                  "    }",
                  "});"
                ],
                "type": "text/javascript"
